# ===== ANSTRACK config =====
# YOU DO NOT NEED AN API KEY TO RUN THIS.
# Leave the keys blank and the brain scores launches from on-chain heuristics (keyless).
# Add a key (or use Ollama) only if you want the LLM to write the reasoning/rug read.

VAULT_PATH=~/pumpfun-vault

# --- LLM brain (OPTIONAL) ---
# Option A — KEYLESS, nothing to install: leave provider=gemini and the key blank.
#            You get the live feed + heuristic scoring, just no written thesis.
# Option B — KEYLESS + full reasoning: install Ollama (ollama.com), `ollama pull llama3`,
#            then set LLM_PROVIDER=ollama. Local model, no key, no cost.
# Option C — Cloud LLM: set a key below.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OLLAMA_MODEL=llama3

# --- PumpPortal ---
# Launches + migrations (the main feed) are FREE / no key.
# A key is ONLY for metered whale-wallet trade following (off by default).
PUMPPORTAL_API_KEY=
ENABLE_WALLET_TRADES=false

ANSTRACK_PORT=8787
ALPHA_WATCH_THRESHOLD=40
ALPHA_ALERT_THRESHOLD=70
